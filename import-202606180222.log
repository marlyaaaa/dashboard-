<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Система продуктивности</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

  :root {
    --bg: #1a1a1c;
    --surface: #222224;
    --surface2: #2a2a2c;
    --border: #363638;
    --border2: #464648;
    --text: #ededea;
    --muted: #888886;
    --muted2: #565654;
    --accent: #ededea;
    --gold: #c8a84a;
    --gold-dim: #7a6428;
    --green: #4a9e6e;
    --red: #b03428;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 32px 16px 64px;
    max-width: 540px;
    margin: 0 auto;
  }

  /* HEADER */
  .header {
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .header h1 {
    font-size: 26px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  .header-date {
    font-size: 12px;
    color: var(--muted);
    margin-top: 6px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* TABS */
  .tabs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--border);
    border-radius: 10px;
    padding: 2px;
    margin-bottom: 28px;
  }
  .tab {
    padding: 8px 4px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.2px;
  }
  .tab.active {
    background: var(--surface2);
    color: var(--gold);
    font-weight: 600;
  }

  /* SECTIONS */
  .section { display: none; }
  .section.active { display: block; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

  /* CARD */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 12px;
  }
  .card-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 14px 0;
  }

  /* SYSTEM — CYCLE */
  .cycle-list { display: flex; flex-direction: column; gap: 0; }
  .cycle-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .cycle-item:last-child { border-bottom: none; }
  .cycle-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gold);
    min-width: 20px;
  }
  .cycle-text { font-size: 13px; color: var(--text); flex: 1; }
  .cycle-arrow { font-size: 11px; color: var(--muted2); }

  /* INFLUENCE GRID */
  .inf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .inf-item {
    background: var(--surface2);
    border-radius: 10px;
    padding: 14px;
  }
  .inf-icon { font-size: 18px; margin-bottom: 6px; }
  .inf-title { font-size: 12px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .inf-arrow { font-size: 10px; color: var(--muted2); margin-bottom: 3px; }
  .inf-result { font-size: 11px; color: var(--muted); line-height: 1.5; }
  .inf-result.bad { color: var(--red); }
  .inf-result.good { color: var(--green); }
  .gold { color: var(--gold); }

  /* RULES */
  .rule-item {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }
  .rule-item:last-child { border-bottom: none; padding-bottom: 0; }
  .rule-n {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gold);
    padding-top: 2px;
    min-width: 18px;
  }
  .rule-body { font-size: 13px; line-height: 1.6; color: var(--text); }
  .rule-body strong { font-weight: 600; }

  /* SLEEP CARD */
  .sleep-times {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 14px;
  }
  .sleep-block {
    background: var(--surface2);
    border-radius: 10px;
    padding: 14px;
    text-align: center;
  }
  .sleep-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 28px;
    font-weight: 500;
    color: var(--gold);
    letter-spacing: -1px;
  }
  .sleep-label { font-size: 11px; color: var(--muted); margin-top: 4px; }

  /* TIMELINE */
  .tl-item {
    display: flex;
    gap: 14px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }
  .tl-item:last-child { border-bottom: none; }
  .tl-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    min-width: 40px;
    padding-top: 3px;
  }
  .tl-content { flex: 1; }
  .tl-tag {
    display: inline-block;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 4px;
    margin-bottom: 4px;
  }
  .tag-work { background: var(--gold); color: #1a1a1c; }
  .tag-rest { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }
  .tag-start { background: var(--surface2); color: var(--gold); border: 1px solid var(--border); }
  .tag-stop  { background: var(--surface2); color: var(--red);   border: 1px solid var(--border); }
  .tl-label { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 2px; }
  .tl-desc  { font-size: 11px; color: var(--muted); line-height: 1.5; }
  .work-hours {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface2);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 14px;
  }
  .wh-label { font-size: 11px; color: var(--muted); }
  .wh-val { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 500; color: var(--gold); }

  /* TRACKER */
  .week-nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .nav-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    width: 28px;
    height: 28px;
    border-radius: 7px;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s;
  }
  .nav-btn:active { background: var(--border); }
  .week-lbl { font-size: 12px; font-weight: 500; font-family: 'JetBrains Mono', monospace; color: var(--muted); }

  .day-labels-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
    margin-bottom: 4px;
    padding-left: 130px;
  }
  @media(max-width:420px) { .day-labels-row { padding-left: 90px; } }
  .day-lbl {
    font-size: 9px;
    font-weight: 600;
    text-align: center;
    color: var(--muted2);
    text-transform: uppercase;
  }
  .day-lbl.today { color: var(--text); font-weight: 700; }

  .habit-row {
    display: grid;
    grid-template-columns: 130px repeat(7, 1fr);
    gap: 3px;
    margin-bottom: 3px;
    align-items: center;
  }
  @media(max-width:420px) { .habit-row { grid-template-columns: 90px repeat(7, 1fr); } }
  .habit-name {
    font-size: 10px;
    color: var(--text);
    padding-right: 8px;
    line-height: 1.3;
  }
  .habit-cell {
    aspect-ratio: 1;
    border-radius: 5px;
    border: 1.5px solid var(--border);
    background: transparent;
    cursor: pointer;
    transition: all 0.12s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: transparent;
  }
  .habit-cell.done { border-color: transparent; color: var(--bg); }
  .habit-cell.future { opacity: 0.25; cursor: default; }
  .habit-cell:not(.future):hover { border-color: var(--border2); }

  /* WALK PROGRESS */
  .walk-card {
    background: var(--surface2);
    border-radius: 10px;
    padding: 14px;
    margin-top: 12px;
  }
  .walk-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .walk-title { font-size: 12px; font-weight: 600; }
  .walk-phase {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }
  .walk-bar-bg {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .walk-bar-fill {
    height: 100%;
    background: var(--gold);
    border-radius: 2px;
    transition: width 0.4s ease;
  }
  .walk-steps-row {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
  }

  /* TODAY SUMMARY */
  .today-summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 14px;
  }
  .ts-card {
    background: var(--surface2);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
  }
  .ts-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px;
    font-weight: 500;
    color: var(--gold);
  }
  .ts-label { font-size: 10px; color: var(--muted); margin-top: 3px; }

  /* STREAK ROW */
  .streak-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .streak-chip {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 6px 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .sc-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    color: var(--gold);
  }
  .sc-label { font-size: 10px; color: var(--muted); }

  /* FINANCE */
  .fin-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px; }
  .fin-block {
    background: var(--surface2);
    border-radius: 10px;
    padding: 14px;
  }
  .fin-lbl { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .fin-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    color: var(--gold);
  }
  .client-slots {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-bottom: 14px;
  }
  .slot {
    aspect-ratio: 1;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    cursor: pointer;
    border: 1.5px solid var(--border);
    transition: all 0.12s;
    background: var(--surface2);
    color: var(--muted2);
    font-size: 12px;
  }
  .slot.filled {
    border-color: var(--gold);
    background: var(--gold);
    color: #1a1a1c;
    font-size: 16px;
  }
  .fin-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; }
  .fin-input-group label { font-size: 10px; color: var(--muted); display: block; margin-bottom: 4px; }
  input[type="number"] {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    padding: 8px 10px;
    width: 100%;
    outline: none;
    transition: border-color 0.15s;
  }
  input[type="number"]:focus { border-color: var(--text); }
  .update-btn {
    background: var(--gold);
    border: none;
    border-radius: 8px;
    color: #1a1a1c;
    font-size: 12px;
    font-weight: 600;
    padding: 10px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    width: 100%;
    transition: opacity 0.15s;
  }
  .update-btn:active { opacity: 0.7; }
  .motivation-msg {
    background: var(--surface2);
    border-radius: 8px;
    padding: 12px;
    font-size: 12px;
    line-height: 1.6;
    color: var(--muted);
    margin-top: 10px;
    display: none;
  }
</style>
</head>
<body>

<div class="header">
  <div class="eyebrow">Система продуктивности</div>
  <h1>Выход из<br>режима расслабона</h1>
  <div class="header-date" id="dateDisplay"></div>
</div>

<div class="tabs">
  <button class="tab active" onclick="showTab('system',this)">Система</button>
  <button class="tab" onclick="showTab('schedule',this)">График</button>
  <button class="tab" onclick="showTab('tracker',this)">Трекер</button>
  <button class="tab" onclick="showTab('finance',this)">Клиенты</button>
</div>

<!-- ══════════ SYSTEM ══════════ -->
<div id="system" class="section active">

  <div class="card">
    <div class="card-label">Твой цикл</div>
    <div class="cycle-list">
      <div class="cycle-item"><span class="cycle-num">01</span><span class="cycle-text">Появляется клиент — деньги есть</span><span class="cycle-arrow">↓</span></div>
      <div class="cycle-item"><span class="cycle-num">02</span><span class="cycle-text">Расслабление, игры, видео</span><span class="cycle-arrow">↓</span></div>
      <div class="cycle-item"><span class="cycle-num">03</span><span class="cycle-text">Сон сдвигается — ложишься в 5 утра</span><span class="cycle-arrow">↓</span></div>
      <div class="cycle-item"><span class="cycle-num">04</span><span class="cycle-text">Нет сил, нет концентрации</span><span class="cycle-arrow">↓</span></div>
      <div class="cycle-item"><span class="cycle-num">05</span><span class="cycle-text">Теряешь клиентов — паника</span><span class="cycle-arrow">↺</span></div>
    </div>
  </div>

  <div class="card">
    <div class="card-label">Что на что влияет</div>
    <div class="inf-grid">
      <div class="inf-item">
        <div class="inf-icon">😴</div>
        <div class="inf-title">Сон в 5 утра</div>
        <div class="inf-arrow">влечёт</div>
        <div class="inf-result bad">−40% силы воли. Нет кортизола. Всё лень.</div>
      </div>
      <div class="inf-item">
        <div class="inf-icon">📱</div>
        <div class="inf-title">Телефон с утра</div>
        <div class="inf-arrow">влечёт</div>
        <div class="inf-result bad">Дофамин с утра — работа скучна весь день</div>
      </div>
      <div class="inf-item">
        <div class="inf-icon">☀️</div>
        <div class="inf-title">Подъём в 8:00</div>
        <div class="inf-arrow">даёт</div>
        <div class="inf-result good">Пик кортизола. Макс. концентрация 9–12</div>
      </div>
      <div class="inf-item">
        <div class="inf-icon">🚶</div>
        <div class="inf-title">Прогулка утром</div>
        <div class="inf-arrow">даёт</div>
        <div class="inf-result good">+30% дофамина. Меньше тяги к играм.</div>
      </div>
      <div class="inf-item">
        <div class="inf-icon">💻</div>
        <div class="inf-title">6 ч глубокой работы</div>
        <div class="inf-arrow">даёт</div>
        <div class="inf-result good">Результат выше нормы. Рост как специалист.</div>
      </div>
      <div class="inf-item">
        <div class="inf-icon">⏱</div>
        <div class="inf-title">Конец дня в 18:00</div>
        <div class="inf-arrow">даёт</div>
        <div class="inf-result good">Мозг не саботирует — знает, что отдых будет</div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-label">3 правила</div>
    <div class="rule-item">
      <div class="rule-n">01</div>
      <div class="rule-body"><strong>Первый час без телефона</strong> — вода, умыться, прогулка. Не кормишь мозг дофамином с утра.</div>
    </div>
    <div class="rule-item">
      <div class="rule-n">02</div>
      <div class="rule-body"><strong>1 час поиска клиентов каждый день</strong> — даже если клиенты есть. Это убирает чувство «всё окей».</div>
    </div>
    <div class="rule-item">
      <div class="rule-n">03</div>
      <div class="rule-body"><strong>Фриланс заканчивается в 18:00</strong> — после спорта идёт блок кода. Игры только с 20:30. Мозг знает структуру и не саботирует.</div>
    </div>
  </div>

  <div class="card">
    <div class="card-label">Целевой режим сна</div>
    <div class="sleep-times">
      <div class="sleep-block">
        <div class="sleep-time">00:00</div>
        <div class="sleep-label">🌙 Отбой</div>
      </div>
      <div class="sleep-block">
        <div class="sleep-time">08:00</div>
        <div class="sleep-label">☀️ Подъём</div>
      </div>
    </div>
    <div style="font-size:12px;color:var(--muted);line-height:1.7">
      8 часов сна — базовое условие для силы воли и концентрации. Кортизол вырабатывается в первые часы после рассвета. Без подъёма в 8:00 — ты его просто пропускаешь.
    </div>
  </div>

  <div class="card" id="progressionCard">
  </div>

</div>

<!-- ══════════ SCHEDULE ══════════ -->
<div id="schedule" class="section">
  <div class="card">
    <div class="work-hours" style="flex-direction:column;gap:8px;align-items:stretch">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div class="wh-label">Фриланс — глубокая работа</div>
        <div class="wh-val">6 ч</div>
      </div>
      <div style="height:1px;background:var(--border)"></div>
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div class="wh-label">Код / ИИ агенты (вечер)</div>
        <div class="wh-val">45 мин</div>
      </div>
    </div>
    <div class="card-label">Расписание дня</div>
    <div>

      <div class="tl-item">
        <div class="tl-time">08:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-start">Старт</span>
          <div class="tl-label">Подъём — без телефона</div>
          <div class="tl-desc">Вода, умыться. 30 минут телефон лежит — критично.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">08:30</div>
        <div class="tl-content">
          <span class="tl-tag tag-start">Тело</span>
          <div class="tl-label">Прогулка — 5 000 шагов</div>
          <div class="tl-desc">Запускает кортизол и метаболизм. Со временем до 10 000.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">09:30</div>
        <div class="tl-content">
          <span class="tl-tag tag-work">Глубокая работа — 2 ч</span>
          <div class="tl-label">Блок #1 — основная задача</div>
          <div class="tl-desc">Пик концентрации. Самое важное — сюда. Телефон убрать.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">11:30</div>
        <div class="tl-content">
          <span class="tl-tag tag-rest">Пауза</span>
          <div class="tl-label">Перерыв — 30 мин</div>
          <div class="tl-desc">Еда, прогулка, не видео. Мозгу нужна настоящая пауза.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">12:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-work">Глубокая работа — 2 ч</span>
          <div class="tl-label">Блок #2 — продолжение или клиенты</div>
          <div class="tl-desc">Второй пик. 1 час из этого — поиск новых клиентов.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">14:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-rest">Обед</span>
          <div class="tl-label">Обед + отдых — 1 час</div>
          <div class="tl-desc">Полноценный отдых. Можно короткий сон 20 мин.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">15:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-work">Глубокая работа — 2 ч</span>
          <div class="tl-label">Блок #3 — фриланс</div>
          <div class="tl-desc">Продолжение клиентских задач. Поиск новых клиентов — 1 час отсюда.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">17:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-rest">Лёгкое</span>
          <div class="tl-label">Письма, план на завтра — 1 час</div>
          <div class="tl-desc">Ответы, планирование, лёгкие задачи. Мозг устал от сложного.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">18:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-start">Тело</span>
          <div class="tl-label">Спорт или прогулка — 1 час</div>
          <div class="tl-desc">Переключение после работы. Мозг перезагружается перед вечерним блоком.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">19:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-work">Код / ИИ — 45 мин</span>
          <div class="tl-label">Вайбкодинг, Claude Code, ИИ агенты</div>
          <div class="tl-desc">Небольшой блок без давления. Главное — делать каждый день, а не много за раз.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">19:45</div>
        <div class="tl-content">
          <span class="tl-tag tag-rest">Личное</span>
          <div class="tl-label">Игры, видео, общение</div>
          <div class="tl-desc">Заслуженный отдых. Ты сделал больше чем 99% людей за день.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">22:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-stop">Стоп</span>
          <div class="tl-label">Экраны на минимум</div>
          <div class="tl-desc">Мелатонин начинает вырабатываться. Яркие экраны блокируют.</div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-time">00:00</div>
        <div class="tl-content">
          <span class="tl-tag tag-stop">Сон</span>
          <div class="tl-label">Отбой</div>
          <div class="tl-desc">8 часов. Просыпаешься в 08:00 с энергией и кортизолом.</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ══════════ TRACKER ══════════ -->
<div id="tracker" class="section">
  <div class="card">
    <div class="week-nav-row">
      <button class="nav-btn" onclick="changeWeek(-1)">‹</button>
      <span class="week-lbl" id="weekLabel">эта неделя</span>
      <button class="nav-btn" onclick="changeWeek(1)">›</button>
    </div>

    <div class="day-labels-row" id="dayLabels"></div>
    <div id="habitRows"></div>

    <div style="background:var(--surface2);border-radius:10px;padding:10px 14px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center" id="miniProgCard">
      <div style="font-size:11px;color:var(--muted)">День прогрессии</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--gold)" id="miniProgDay"></div>
    </div>
    <div class="walk-card" id="walkCard">
      <div class="walk-header">
        <div class="walk-title">🚶 Прогрессия прогулки</div>
        <div class="walk-phase" id="walkPhase">5 000 шагов</div>
      </div>
      <div class="walk-bar-bg">
        <div class="walk-bar-fill" id="walkBarFill" style="width:0%"></div>
      </div>
      <div class="walk-steps-row">
        <span>5 000</span>
        <span id="walkProgress">0 дней выполнено</span>
        <span>10 000</span>
      </div>
    </div>

    <div class="today-summary" id="todaySummary"></div>
    <div class="streak-row" id="streakRow"></div>
  </div>
</div>

<!-- ══════════ FINANCE ══════════ -->
<div id="finance" class="section">
  <div class="card">
    <div class="card-label">Доход</div>
    <div class="fin-grid">
      <div class="fin-block">
        <div class="fin-lbl">Сейчас / мес</div>
        <div class="fin-val" id="currentIncome">—</div>
      </div>
      <div class="fin-block">
        <div class="fin-lbl">Цель / мес</div>
        <div class="fin-val" id="targetIncome">—</div>
      </div>
      <div class="fin-block">
        <div class="fin-lbl">Клиентов</div>
        <div class="fin-val" id="currentClients">0</div>
      </div>
      <div class="fin-block">
        <div class="fin-lbl">Нужно ещё</div>
        <div class="fin-val" id="neededClients">—</div>
      </div>
    </div>

    <div class="card-label">Слоты клиентов</div>
    <div class="client-slots" id="clientSlots"></div>

    <div class="fin-inputs">
      <div class="fin-input-group">
        <label>Доход с 1 клиента</label>
        <input type="number" id="perClientInput" placeholder="5000" min="0">
      </div>
      <div class="fin-input-group">
        <label>Целевых клиентов</label>
        <input type="number" id="targetClientsInput" placeholder="8" min="1" max="20">
      </div>
    </div>
    <button class="update-btn" onclick="updateFinance()">Обновить</button>
    <div class="motivation-msg" id="motivationMsg"></div>
  </div>

  <div class="card">
    <div class="card-label">Правило</div>
    <div style="font-size:13px;color:var(--muted);line-height:1.7">
      Каждый день — <span style="color:var(--text);font-weight:600">1 час на поиск клиентов</span>. Даже если все слоты заняты. Это формирует очередь и повышает твою ценность. Пустой слот = реальные упущенные деньги.
    </div>
  </div>
</div>

<script>
// ── HABITS ─────────────────────────────────────────────────────
const habits = [
  { id: 'sleep',   name: 'Лёг до 00:00',           color: '#6b6b80' },
  { id: 'wake',    name: 'Встал до 08:30',          color: '#8a8a85' },
  { id: 'noPhone', name: 'Без телефона 30 мин',     color: '#c0392b' },
  { id: 'walk',    name: 'Прогулка утром',          color: '#2d6a4f' },
  { id: 'work1',   name: 'Блок #1 работа',           color: '#c8a84a' },
  { id: 'work2',   name: 'Блок #2 работа',           color: '#c8a84a' },
  { id: 'work3',   name: 'Вечер: код / ИИ агенты',  color: '#c8a84a' },
  { id: 'search',  name: 'Поиск клиентов',          color: '#2d6a4f' },
  { id: 'noGames', name: 'Игры после 18:00',        color: '#c0392b' },
];

const days = ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'];
let weekOffset = 0;
let trackerData = JSON.parse(localStorage.getItem('pd_tracker') || '{}');
let financeData = JSON.parse(localStorage.getItem('pd_finance') || '{"clients":[],"perClient":0,"targetClients":8}');

// ── DATE UTILS ─────────────────────────────────────────────────
function getWeekStart(off = 0) {
  const now = new Date();
  const day = now.getDay();
  const diff = day === 0 ? -6 : 1 - day;
  const mon = new Date(now);
  mon.setDate(now.getDate() + diff + off * 7);
  mon.setHours(0,0,0,0);
  return mon;
}
function dKey(d) { return d.toISOString().split('T')[0]; }
function getWeekDates(off = 0) {
  const start = getWeekStart(off);
  return Array.from({length:7}, (_,i) => { const d=new Date(start); d.setDate(start.getDate()+i); return d; });
}

// ── WALK PROGRESSION ───────────────────────────────────────────
function getWalkStats() {
  // Count total walk completions ever
  let total = 0;
  Object.values(trackerData).forEach(day => { if (day.walk) total++; });
  // Phase: 0-20 days = 5000, 21-40 = 7500, 41+ = 10000
  let target = 5000, phase = '5 000 шагов';
  if (total >= 41) { target = 10000; phase = '10 000 шагов'; }
  else if (total >= 21) { target = 7500; phase = '7 500 шагов'; }
  const pct = Math.min(100, Math.round((total % 20) / 20 * 100));
  return { total, target, phase, pct };
}

// ── TRACKER RENDER ─────────────────────────────────────────────
function renderTracker() {
  const dates = getWeekDates(weekOffset);
  const today = dKey(new Date());

  // Week label
  const ws = getWeekStart(weekOffset);
  const we = new Date(ws); we.setDate(ws.getDate()+6);
  const fmt = d => `${d.getDate()}.${String(d.getMonth()+1).padStart(2,'0')}`;
  document.getElementById('weekLabel').textContent =
    weekOffset === 0 ? 'эта неделя' : `${fmt(ws)} – ${fmt(we)}`;

  // Day labels
  document.getElementById('dayLabels').innerHTML = days.map((d,i) => {
    const isToday = dKey(dates[i]) === today;
    return `<div class="day-lbl${isToday?' today':''}">${d}</div>`;
  }).join('');

  // Habit rows
  document.getElementById('habitRows').innerHTML = habits.map(h => {
    const cells = dates.map(date => {
      const k = dKey(date);
      const done = trackerData[k]?.[h.id];
      const future = date > new Date() && k !== today;
      return `<div class="habit-cell${done?' done':''}${future?' future':''}"
        style="${done?`background:${h.color};border-color:${h.color}`:''}${future?';pointer-events:none':''}"
        onclick="${future?'':` toggleHabit('${k}','${h.id}')`}">✓</div>`;
    }).join('');
    return `<div class="habit-row"><div class="habit-name">${h.name}</div>${cells}</div>`;
  }).join('');

  // Walk card
  const ws2 = getWalkStats();
  document.getElementById('walkPhase').textContent = ws2.phase;
  document.getElementById('walkBarFill').style.width = ws2.pct + '%';
  document.getElementById('walkProgress').textContent = `${ws2.total} дн. выполнено`;

  // Today summary
  const td = trackerData[today] || {};
  const done = habits.filter(h => td[h.id]).length;
  const pct = Math.round(done / habits.length * 100);
  document.getElementById('todaySummary').innerHTML = `
    <div class="ts-card"><div class="ts-val">${done}/${habits.length}</div><div class="ts-label">привычек сегодня</div></div>
    <div class="ts-card"><div class="ts-val">${pct}%</div><div class="ts-label">выполнено</div></div>`;

  // Streaks for first 4 habits
  // Mini progression display
  var mp = getProgression();
  var miniEl = document.getElementById('miniProgDay');
  if (miniEl) miniEl.textContent = mp.days + '/14 — ' + mp.pct + '%';

  document.getElementById('streakRow').innerHTML = habits.slice(0,4).map(h => {
    let streak = 0;
    const now = new Date();
    for (let i = 0; i < 60; i++) {
      const d = new Date(now); d.setDate(now.getDate()-i);
      if (trackerData[dKey(d)]?.[h.id]) streak++;
      else if (i > 0) break;
    }
    return `<div class="streak-chip"><span class="sc-num">${streak}</span><span class="sc-label">${h.name.split(' ').slice(-1)[0]}</span></div>`;
  }).join('');
}

function toggleHabit(dateKey, habitId) {
  if (!trackerData[dateKey]) trackerData[dateKey] = {};
  trackerData[dateKey][habitId] = !trackerData[dateKey][habitId];
  localStorage.setItem('pd_tracker', JSON.stringify(trackerData));
  renderTracker();
}

function changeWeek(dir) {
  weekOffset = Math.min(0, weekOffset + dir);
  renderTracker();
}

// ── FINANCE ────────────────────────────────────────────────────
function renderFinanceSlots() {
  const target = financeData.targetClients || 8;
  const clients = financeData.clients || [];
  document.getElementById('clientSlots').innerHTML = Array.from({length:target}, (_,i) => {
    const filled = clients[i];
    return `<div class="slot${filled?' filled':''}" onclick="toggleClient(${i})">${filled?'👤':'+'}</div>`;
  }).join('');
}

function toggleClient(i) {
  const c = financeData.clients || [];
  while (c.length <= i) c.push(false);
  c[i] = !c[i];
  financeData.clients = c;
  saveFinance(); updateFinanceDisplay();
}

function updateFinance() {
  financeData.perClient = parseFloat(document.getElementById('perClientInput').value) || 0;
  financeData.targetClients = parseInt(document.getElementById('targetClientsInput').value) || 8;
  saveFinance(); updateFinanceDisplay();
}

function updateFinanceDisplay() {
  const clients = (financeData.clients||[]).filter(Boolean).length;
  const per = financeData.perClient || 0;
  const target = financeData.targetClients || 8;
  const needed = target - clients;

  document.getElementById('currentClients').textContent = clients;
  document.getElementById('neededClients').textContent = needed > 0 ? needed : '✓';
  document.getElementById('currentIncome').textContent = per > 0 ? `${(clients*per).toLocaleString('ru')} ₽` : '—';
  document.getElementById('targetIncome').textContent = per > 0 ? `${(target*per).toLocaleString('ru')} ₽` : '—';
  renderFinanceSlots();

  const msg = document.getElementById('motivationMsg');
  if (per > 0) {
    msg.style.display = 'block';
    if (needed <= 0) msg.textContent = 'Все слоты заняты. Время поднять цену или открыть новую очередь.';
    else if (clients === 0) msg.textContent = 'Нет ни одного клиента. Поиск сегодня — задача #1.';
    else msg.textContent = `До цели: ${needed} клиент${needed>1?'ов':''} — ещё ${(needed*per).toLocaleString('ru')} ₽/мес. Пустой слот = упущенные деньги.`;
  }
}

function saveFinance() { localStorage.setItem('pd_finance', JSON.stringify(financeData)); }

// ── TABS ───────────────────────────────────────────────────────
function showTab(name, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById(name).classList.add('active');
  btn.classList.add('active');
}

// ── PROGRESSION SYSTEM ────────────────────────────────────────
function getOrSetStartDate() {
  let start = localStorage.getItem('pd_startDate');
  if (!start) {
    start = new Date().toISOString().split('T')[0];
    localStorage.setItem('pd_startDate', start);
  }
  return new Date(start);
}

function getDaysSinceStart() {
  const start = getOrSetStartDate();
  const now = new Date();
  const diff = Math.floor((now - start) / (1000 * 60 * 60 * 24));
  return Math.max(0, diff);
}

function getWeeksSinceStart() {
  return Math.floor(getDaysSinceStart() / 7);
}

function getProgression() {
  const weeks = getWeeksSinceStart();
  const days = getDaysSinceStart();
  const t = Math.min(1, days / 14); // 0..1 over 14 days

  // Steps: 5000 → 7500 (week 1) → 10000 (week 2)
  let steps, stepsLabel;
  if (days < 7)       { steps = 5000;  stepsLabel = '5 000'; }
  else if (days < 14) { steps = 7500;  stepsLabel = '7 500'; }
  else                { steps = 10000; stepsLabel = '10 000'; }

  // Sleep: wake 09:00→07:00, bed 02:00→00:00 over 14 days
  const wakeHour = Math.round(9 - (2 * t));   // 9→7
  const bedHour  = Math.round(2 - (2 * t));   // 2→0
  const wakeStr  = `0${wakeHour}:00`.slice(-5);
  const bedStr   = bedHour === 0 ? '00:00' : `0${bedHour}:00`.slice(-5);

  // Freelance blocks: 1.5h→2h over 14 days
  const blockMin = Math.round(90 + (30 * t)); // 90→120 min
  const blockH   = blockMin === 90 ? '1.5 ч' : blockMin === 120 ? '2 ч' : `${(blockMin/60).toFixed(1)} ч`;
  const totalFreelance = blockMin === 90 ? '4.5 ч' : blockMin === 120 ? '6 ч' : `${((blockMin*3)/60).toFixed(1)} ч`;

  // Coding: 30min→1h over 14 days
  const codeMin = Math.round(30 + (30 * t)); // 30→60 min
  const codeStr = codeMin >= 60 ? '1 ч' : `${codeMin} мин`;

  // Progress percent
  const pct = Math.round(t * 100);

  return { steps, stepsLabel, wakeStr, bedStr, blockH, totalFreelance, codeMin, codeStr, pct, days, weeks };
}

function renderProgressionCard() {
  var p = getProgression();
  var card = document.getElementById('progressionCard');
  if (!card) return;

  var finishMsg = p.days >= 14
    ? '<div style="margin-top:12px;padding:10px 14px;background:rgba(200,168,74,0.1);border:1px solid rgba(200,168,74,0.3);border-radius:8px;font-size:12px;color:var(--gold);text-align:center">&#10003; Финальный уровень достигнут. Держи его.</div>'
    : '<div style="margin-top:12px;font-size:11px;color:var(--muted);text-align:center">До финального уровня: ' + (14 - p.days) + ' дн.</div>';

  card.innerHTML =
    '<div class="card-label">Автопрогрессия — день ' + p.days + ' из 14</div>' +
    '<div style="height:4px;background:var(--border);border-radius:2px;margin-bottom:16px;overflow:hidden">' +
      '<div style="height:100%;width:' + p.pct + '%;background:var(--gold);border-radius:2px;transition:width 0.5s ease"></div>' +
    '</div>' +
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">' +
      '<div style="background:var(--surface2);border-radius:10px;padding:12px">' +
        '<div style="font-size:10px;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px">Прогулка</div>' +
        '<div style="font-family:JetBrains Mono,monospace;font-size:18px;font-weight:500;color:var(--gold)">' + p.stepsLabel + '</div>' +
        '<div style="font-size:10px;color:var(--muted);margin-top:2px">шагов вечером</div>' +
      '</div>' +
      '<div style="background:var(--surface2);border-radius:10px;padding:12px">' +
        '<div style="font-size:10px;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px">Сон</div>' +
        '<div style="font-family:JetBrains Mono,monospace;font-size:14px;font-weight:500;color:var(--gold)">' + p.wakeStr + ' / ' + p.bedStr + '</div>' +
        '<div style="font-size:10px;color:var(--muted);margin-top:2px">подъём / отбой</div>' +
      '</div>' +
      '<div style="background:var(--surface2);border-radius:10px;padding:12px">' +
        '<div style="font-size:10px;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px">Фриланс блок</div>' +
        '<div style="font-family:JetBrains Mono,monospace;font-size:18px;font-weight:500;color:var(--gold)">' + p.blockH + '</div>' +
        '<div style="font-size:10px;color:var(--muted);margin-top:2px">итого ' + p.totalFreelance + '/день</div>' +
      '</div>' +
      '<div style="background:var(--surface2);border-radius:10px;padding:12px">' +
        '<div style="font-size:10px;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px">Код / ИИ</div>' +
        '<div style="font-family:JetBrains Mono,monospace;font-size:18px;font-weight:500;color:var(--gold)">' + p.codeStr + '</div>' +
        '<div style="font-size:10px;color:var(--muted);margin-top:2px">вечерний блок</div>' +
      '</div>' +
    '</div>' +
    finishMsg;
}

// ── INIT ───────────────────────────────────────────────────────
document.getElementById('dateDisplay').textContent =
  new Date().toLocaleDateString('ru', {weekday:'long', day:'numeric', month:'long'});

if (financeData.perClient) document.getElementById('perClientInput').value = financeData.perClient;
if (financeData.targetClients) document.getElementById('targetClientsInput').value = financeData.targetClients;

renderTracker();
renderFinanceSlots();
updateFinanceDisplay();
renderProgressionCard();
</script>
</body>
</html>